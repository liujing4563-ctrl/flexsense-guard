{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/liujing4563-ctrl/flexsense-guard/schemas/system_state.schema.json",
    "title": "系统状态",
    "description": "Observer、Confidence、Classification 和 Mode Manager 共同产生的公共状态输出",
    "type": "object",
    "properties": {
        "timestamp_s": {
            "type": "number",
            "minimum": 0,
            "description": "当前仿真时间，单位为秒"
        },
        "estimated_load_position_rad": {
            "type": "number",
            "description": "负载侧位置估计，单位为弧度"
        },
        "estimated_load_velocity_rad_s": {
            "type": "number",
            "description": "负载侧速度估计，单位为弧度每秒"
        },
        "estimated_torsion_rad": {
            "type": "number",
            "description": "扭转角估计 theta_m/N - theta_l，单位为弧度"
        },
        "estimated_external_torque_nm": {
            "type": "number",
            "description": "外部关节扰动力矩估计，单位为牛米"
        },
        "innovation_norm": {
            "type": "number",
            "minimum": 0,
            "description": "Observer 创新残差的二范数"
        },
        "confidence_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "工程可信评分，越高表示越可信，不是概率"
        },
        "contact_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "接触证据评分，不是概率"
        },
        "classification_state": {
            "type": "string",
            "enum": [
                "NORMAL",
                "FLEXIBLE_VIBRATION",
                "EXTERNAL_CONTACT",
                "LOW_CONFIDENCE"
            ],
            "description": "跨语言统一的分类状态"
        },
        "operation_mode": {
            "type": "string",
            "enum": [
                "NORMAL_TRACKING",
                "VIBRATION_SUPPRESSION",
                "SAFE_SLOWDOWN",
                "LOW_CONFIDENCE_DEGRADED"
            ],
            "description": "跨语言统一的运行模式"
        },
        "valid_flag": {
            "type": "boolean",
            "description": "当前状态是否可供下游模块使用"
        },
        "reason_codes": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "NONE",
                    "INVALID_TIMESTAMP",
                    "INVALID_ENCODER",
                    "INVALID_CURRENT",
                    "TORQUE_SATURATED",
                    "LOW_CONFIDENCE"
                ]
            },
            "uniqueItems": true,
            "description": "估计有效或降级的可追溯原因"
        }
    },
    "required": [
        "timestamp_s",
        "estimated_load_position_rad",
        "estimated_load_velocity_rad_s",
        "estimated_torsion_rad",
        "estimated_external_torque_nm",
        "innovation_norm",
        "confidence_score",
        "contact_score",
        "classification_state",
        "operation_mode",
        "valid_flag",
        "reason_codes"
    ],
    "additionalProperties": false
}
