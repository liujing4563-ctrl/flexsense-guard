{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/liujing4563-ctrl/flexsense-guard/common/schemas/scenario_config.schema.json",
  "title": "场景配置",
  "description": "关联不可变 Plant 真值配置与独立名义参数版本，不内嵌运行时真值",
  "type": "object",
  "properties": {
    "schema_version": {"$ref": "contract_common.schema.json#/$defs/schema_version"},
    "configuration_id": {"type": "string", "minLength": 1},
    "scenario_id": {"type": "string", "minLength": 1},
    "plant_true_configuration_id": {"type": "string", "minLength": 1},
    "nominal_parameter_version": {"type": "string", "minLength": 1},
    "dataset_partition": {
      "type": "string",
      "enum": ["TUNING", "ACCEPTANCE", "EVALUATION"]
    },
    "payload_level": {
      "type": "string",
      "enum": ["light", "medium", "heavy"]
    },
    "sample_time_s": {"type": "number", "exclusiveMinimum": 0},
    "duration_s": {"type": "number", "exclusiveMinimum": 0},
    "collision_time_s": {
      "type": ["number", "null"],
      "minimum": 0,
      "description": "null 表示不注入接触，不使用负数哨兵值"
    },
    "encoder_dropout_rate": {"type": "number", "minimum": 0, "maximum": 1},
    "current_noise_std_a": {"type": "number", "minimum": 0},
    "torque_constant_error_ratio": {"type": "number"},
    "observer_parameter_mismatch_ratio": {"type": "number"},
    "random_seed": {"type": "integer", "minimum": 0}
  },
  "required": [
    "schema_version",
    "configuration_id",
    "scenario_id",
    "plant_true_configuration_id",
    "nominal_parameter_version",
    "dataset_partition",
    "payload_level",
    "sample_time_s",
    "duration_s",
    "random_seed"
  ],
  "additionalProperties": false
}
