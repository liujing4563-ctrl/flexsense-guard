{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/liujing4563-ctrl/flexsense-guard/schemas/scenario_config.schema.json",
    "title": "ScenarioConfig",
    "description": "Configuration schema for simulation scenarios in FlexSense-Guard",
    "type": "object",
    "properties": {
        "schema_version": {
            "type": "string",
            "description": "Schema version (semver)",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "scenario_id": {
            "type": "string",
            "description": "Unique scenario identifier"
        },
        "payload_level": {
            "type": "string",
            "enum": ["light", "medium", "heavy"],
            "description": "Payload level"
        },
        "sample_time_s": {
            "type": "number",
            "exclusiveMinimum": 0,
            "description": "Simulation sampling time [s]"
        },
        "duration_s": {
            "type": "number",
            "exclusiveMinimum": 0,
            "description": "Total simulation duration [s]"
        },
        "collision_time_s": {
            "type": "number",
            "minimum": -1,
            "description": "External contact injection time [s]; -1 means no contact"
        },
        "encoder_dropout_rate": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Encoder dropout probability [0, 1]"
        },
        "current_noise_std": {
            "type": "number",
            "minimum": 0,
            "description": "Current measurement noise standard deviation [A]"
        },
        "torque_constant_error": {
            "type": "number",
            "description": "Torque constant deviation ratio (e.g., 0.1 = 10% error)"
        },
        "observer_parameter_mismatch": {
            "type": "number",
            "description": "Observer parameter mismatch ratio (e.g., 0.2 = 20% mismatch)"
        },
        "random_seed": {
            "type": "integer",
            "description": "Random seed for reproducibility; 0 means not fixed"
        }
    },
    "required": [
        "schema_version",
        "scenario_id",
        "payload_level",
        "sample_time_s",
        "duration_s"
    ],
    "additionalProperties": false
}
