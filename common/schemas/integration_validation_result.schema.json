{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/liujing4563-ctrl/flexsense-guard/common/schemas/integration_validation_result.schema.json",
  "title": "集成验证结果",
  "type": "object",
  "properties": {
    "contract_replay_passed": {"type": "boolean"},
    "component_versions": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "string"}
    },
    "contract_violation_count": {"type": "integer", "minimum": 0}
  },
  "required": ["contract_replay_passed", "component_versions", "contract_violation_count"],
  "additionalProperties": false
}
