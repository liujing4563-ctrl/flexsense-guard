{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/liujing4563-ctrl/flexsense-guard/common/schemas/validation_report.schema.json",
  "title": "阶段化验证报告",
  "allOf": [
    {"$ref": "validation_report_envelope.schema.json"},
    {
      "type": "object",
      "properties": {
        "result": {}
      },
      "required": ["result"]
    },
    {
      "oneOf": [
        {"properties": {"stage": {"const": "P1"}, "result": {"$ref": "p1_validation_result.schema.json"}}},
        {"properties": {"stage": {"const": "P2"}, "result": {"$ref": "p2_validation_result.schema.json"}}},
        {"properties": {"stage": {"const": "P3"}, "result": {"$ref": "p3_validation_result.schema.json"}}},
        {"properties": {"stage": {"const": "SIL"}, "result": {"$ref": "sil_validation_result.schema.json"}}},
        {"properties": {"stage": {"const": "INTEGRATION"}, "result": {"$ref": "integration_validation_result.schema.json"}}}
      ]
    }
  ],
  "unevaluatedProperties": false
}
